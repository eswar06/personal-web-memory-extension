{
  "manifest_version": 3,
  "name": "Personal Web Memory",
  "version": "0.1.0",
  "permissions": ["contextMenus", "tabs", "storage"],
  "background": {
    "service_worker": "serviceWorker.js"
  },
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["tracker.js"],
      "run_at": "document_idle"
    }
  ]
}
